aws_region   = "ap-northeast-1"
project_name = "slalom-aidd-course"
environment  = "dev"

vpc_cidr              = "10.0.0.0/16"
public_subnet_1_cidr  = "10.0.1.0/24"
public_subnet_2_cidr  = "10.0.2.0/24"
private_subnet_1_cidr = "10.0.11.0/24"
private_subnet_2_cidr = "10.0.12.0/24"

allowed_ssh_cidrs = [
  "192.0.2.0/24",
  "198.51.100.0/24",
  "203.0.113.0/24"
]

bastion_instance_type = "t3.micro"

db_username                = "adminuser"
db_instance_class          = "db.t3.micro"
db_allocated_storage       = 20
db_max_allocated_storage   = 100
db_engine                  = "sqlserver-ex"
db_major_engine_version    = "16.00"
db_engine_version          = "16.00.4245.2.v1"
db_parameter_group_family  = "sqlserver-ex-16.0"

multi_az                = false
backup_retention_period = 7
deletion_protection     = false
skip_final_snapshot     = true
apply_immediately       = false

ec2_key_pair_name = "slalom-aidd-course-bastion-key"

restore_s3_bucket_name = "slalom-aidd-course-s3"

owner_suffix = "sj"